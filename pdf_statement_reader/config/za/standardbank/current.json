{
    "$schema": "https://raw.githubusercontent.com/marlanperumal/pdf_statement_reader/develop/pdf_statement_reader/config/psr_config.schema.json",
    "use_pdfplumber": true,
    "pdfplumber_columns": {
        "date_max": 95,
        "ref_min": 95,
        "ref_max": 310,
        "in_min": 310,
        "in_max": 370,
        "out_min": 370,
        "out_max": 440,
        "bal_min": 500,
        "table_top": 220,
        "table_bottom": 760,
        "proximity": 12
    },
    "columns": {
        "trans_date": "Date",
        "trans_type": "Description",
        "debit": "Amount",
        "balance": "Balance"
    },
    "order": [
        "trans_date",
        "trans_type",
        "debit",
        "balance"
    ],
    "cleaning": {
        "comma_decimal": true,
        "date_format": "%d %b %Y"
    }
}
